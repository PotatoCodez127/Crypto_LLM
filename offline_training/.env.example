# Point Aider to your local proxy instead of the cloud
OPENAI_API_BASE=http://localhost:4000
OPENAI_API_KEY=sk-dummy-key-not-used

# Default Model Selection
AIDER_MODEL=openai/deepseek-v3.2

# Your pool of Ollama Cloud Keys (read by the proxy)
OLLAMA_KEY_1=api_key
OLLAMA_KEY_2=api_key
OLLAMA_KEY_3=api_key
OLLAMA_KEY_4=api_key